PORT=3000
# Em produção: defina para endurecer (CLIENT_TOKEN ignorado sem flag abaixo)
# NODE_ENV=production

# Obrigatório: segredo para JWT (ex.: openssl rand -base64 48)
JWT_SECRET=altere-com-segredo-longo-aleatorio

# Opcional: token estático (só dev, ou prod com ALLOW_CLIENT_TOKEN_IN_PRODUCTION=1)
# CLIENT_TOKEN=
# ALLOW_CLIENT_TOKEN_IN_PRODUCTION=1

# Atrás de Cloudflare/nginx — rate limit usa o IP real
# TRUST_PROXY=1

# CORS: * (padrão) ou origens separadas por vírgula (alinhado ao Socket.IO)
# CORS_ORIGIN=*

# Limite de RAM do Node no `npm start` (~384 MiB heap; VM ~1 GiB). Para soltar: npm run start:no-heap-cap
# (o limite vem do script start no package.json)

# Custo bcrypt novas senhas (10–12; padrão 10 = mais rápido e ainda seguro)
# BCRYPT_ROUNDS=10

# Rate limit /auth (ajuste se precisar)
# AUTH_LOGIN_RATE_LIMIT_MAX=20
# AUTH_REGISTER_RATE_LIMIT_MAX=8

# Pasta das sessões Baileys (uma subpasta por usuário)
# AUTH_DIR=/var/lib/iamlive/auth

# MariaDB / MySQL (obrigatório): URL ou variáveis separadas
# DATABASE_URL=mysql://usuario:senha@137.131.168.10:3306/iamlive
# MYSQL_HOST=137.131.168.10
# MYSQL_PORT=3306
# MYSQL_USER=iamlive
# MYSQL_PASSWORD=senha
# MYSQL_DATABASE=iamlive
# MYSQL_POOL_MAX=5
# DATABASE_SSL=1
# DATABASE_SSL_REJECT_UNAUTHORIZED=0

# URL pública do servidor (aparece nas páginas legais, recuperação de senha e links dos termos)
PUBLIC_ORIGIN=https://api-ial.cloudive.com.br

# E-mail (recuperação de senha). Sem isto, o link só aparece nos logs do servidor.
# Use uma destas formas de remetente:
#   SMTP_FROM="Estou Vivo <noreply@seudominio.com>"
# ou nome + e-mail separados:
#   SMTP_FROM_NAME=Estou Vivo
#   SMTP_FROM_EMAIL=noreply@seudominio.com
#
# Zoho Mail: smtp.zoho.com, porta 587, SMTP_SECURE=false (STARTTLS).
# Microsoft 365 / Outlook: smtp.office365.com, mesma porta; o utilizador SMTP deve ser o e-mail da conta.
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_PASSWORD=
# SMTP_FROM_NAME=Estou Vivo
# SMTP_FROM_EMAIL=
# PASSWORD_RESET_TTL_MS=3600000
# AUTH_FORGOT_RATE_LIMIT_MAX=10

# Identificação legal nas páginas /legal/* (LGPD / termos) — recomendado em produção
# Pessoa física: CPF (não defina LEGAL_OPERATOR_CNPJ). Empresa: CNPJ (CPF opcional).
# LEGAL_OPERATOR_NAME=Edson Cantuaria
# LEGAL_OPERATOR_CPF=188.244.607-04
# LEGAL_CONTACT_EMAIL=contato@cloudive.com.br
# LEGAL_ADDRESS=Rua Almeida e Sousa, 1143 — Rio de Janeiro/RJ — CEP 21745-310
# LEGAL_DPO_EMAIL=servicos@cloudive.com.br
#
# Exemplo empresa (em vez do CPF acima, use CNPJ e ajuste nome/e-mails):
# LEGAL_OPERATOR_NAME=Razão social Ltda.
# LEGAL_OPERATOR_CNPJ=00.000.000/0001-00
# LEGAL_CONTACT_EMAIL=privacidade@seudominio.com.br
# LEGAL_ADDRESS=Rua Exemplo, 123 — Cidade/UF — CEP
# LEGAL_DPO_EMAIL=dpo@seudominio.com.br

# error = silencioso (recomendado) | debug = muito log do Baileys
LOG_LEVEL=error
# Opcional: só o client_revision (ex.: 1034074495) ou tripla "2,3000,1034074495" se o fetch da versão falhar / der 405
# WA_WEB_VERSION=1034074495

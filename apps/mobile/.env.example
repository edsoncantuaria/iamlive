# Opcional: só para desenvolvimento local. Sem isto, o app usa https://api-ial.cloudive.com.br (definido no código).
# EXPO_PUBLIC_SERVER_URL=http://192.168.0.30:3000

# iOS (widget + targets): Team ID de 10 caracteres em developer.apple.com — evita aviso do @bacons/apple-targets no prebuild.
# No EAS, pode definir como variável de ambiente do projeto em vez de commitar aqui.
# EXPO_APPLE_TEAM_ID=ABCDE12345
